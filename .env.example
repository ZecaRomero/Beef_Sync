# Configurações do Banco de Dados PostgreSQL
# ===========================================
# OPÇÃO 1 - Supabase (recomendado para acesso pelo celular com PC desligado):
# Pegue em: Supabase Dashboard → Settings → Database → Connection string (URI)
# DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[SENHA]@aws-0-[REGIAO].pooler.supabase.com:6543/postgres?pgbouncer=true
#
# OPÇÃO 2 - Neon/Vercel:
# DATABASE_URL=postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
#
# OPÇÃO 3 - Local: use as variáveis abaixo
DB_HOST=localhost
DB_PORT=5432
DB_NAME=beef_sync
DB_USER=postgres
DB_PASSWORD=sua_senha_aqui
DB_SSL=false

# Configurações do Pool de Conexões
DB_MAX_CONNECTIONS=20
DB_IDLE_TIMEOUT=30000
# Timeout de conexão em ms (2000 = 2s; evita travar o app se o banco estiver lento/indisponível)
DB_CONNECTION_TIMEOUT=2000

# Configurações da Aplicação
NODE_ENV=development
NEXT_PUBLIC_APP_NAME=Beef Sync
NEXT_PUBLIC_APP_VERSION=3.0.0

# Configurações de Backup (opcional)
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=30

# Configurações de Email (opcional - necessário para envio de relatórios)
# Para Gmail: use uma "Senha de App" em https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=seu-email@gmail.com
SMTP_PASS=sua-senha-de-app
SMTP_FROM=noreply@beefsync.com

# Configurações de WhatsApp (opcional - escolha UMA opção)
# Opção 1: Evolution API (recomendado)
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=sua-chave-api
EVOLUTION_INSTANCE_NAME=default

# Opção 2: Twilio WhatsApp Business API
# TWILIO_ACCOUNT_SID=seu-account-sid
# TWILIO_AUTH_TOKEN=seu-auth-token
# TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Configurações de Log
NEXT_PUBLIC_LOG_LEVEL=DEBUG

# Supabase (para acesso na nuvem - opcional, use com DATABASE_URL)
# Pegue em: Supabase Dashboard → Settings → API
# NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key
# SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key
# (necessário para cadastrar usuário Adelso - Settings → API → service_role)